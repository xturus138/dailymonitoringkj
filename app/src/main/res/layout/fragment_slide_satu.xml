<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/containerTable"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    tools:context=".ui.main.slide1.SlideSatu">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/dimen_margin_large">

            <TextView
                android:id="@+id/tvTitleKehadiran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KEHADIRAN STAFF"
                style="@style/font24.bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <View
                android:id="@+id/lineKehadiran"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/dark_blue"
                android:layout_marginTop="@dimen/dimen_margin_2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTitleKehadiran"/>

            <LinearLayout
                android:id="@+id/linearLayoutHeaderKehadiran"
                android:layout_width="match_parent"
                android:layout_height="@dimen/signage_header_height"
                android:paddingTop="@dimen/dimen_padding_10"
                android:paddingBottom="@dimen/dimen_padding_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lineKehadiran"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="NAMA STAFF"
                    style="@style/font14.boldS"
                    android:textAlignment="center"
                    android:gravity="center"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_weight="1"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="STATUS KEHADIRAN"
                    android:textAlignment="center"
                    android:gravity="center"
                    android:singleLine="true"
                    android:ellipsize="end"
                    style="@style/font14.boldS"
                    android:layout_weight="1.5"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="KETERANGAN"
                    style="@style/font14.boldS"
                    android:textAlignment="center"
                    android:gravity="center"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_weight="1"/>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvKehadiran"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@+id/linearLayoutHeaderKehadiran"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:listitem="@layout/item_kehadiran" />


        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tvTitleMeeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MEETING HARI INI"
                style="@style/font24.bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <View
                android:id="@+id/lineMeeting"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/dark_blue"
                android:layout_marginTop="@dimen/dimen_margin_2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTitleMeeting"/>

            <LinearLayout
                android:id="@+id/linearLayoutHeaderMeeting"
                android:layout_width="match_parent"
                android:layout_height="@dimen/signage_header_height"
                android:paddingTop="@dimen/dimen_padding_10"
                android:paddingBottom="@dimen/dimen_padding_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lineMeeting"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="WAKTU (WIB)"
                    style="@style/font14.boldS"
                    android:textAlignment="center"
                    android:gravity="center"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_weight="1"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="JUDUL MEETING"
                    android:textAlignment="center"
                    android:gravity="center"
                    android:singleLine="true"
                    android:ellipsize="end"
                    style="@style/font14.boldS"
                    android:layout_weight="1.5"/>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMeeting"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@+id/linearLayoutHeaderMeeting"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:listitem="@layout/item_meeting" />

        </androidx.constraintlayout.widget.ConstraintLayout>


    </LinearLayout>
