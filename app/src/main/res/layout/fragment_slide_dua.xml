<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/background"
    android:paddingStart="@dimen/dimen_padding_48"
    android:paddingEnd="@dimen/dimen_padding_48"
    android:paddingTop="@dimen/dimen_padding_35"
    android:paddingBottom="@dimen/dimen_padding_35"
    tools:context=".ui.main.slide2.SlideDua">

    <!-- Watermark logo background -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/karirjepang"
        android:alpha="0.08"
        android:scaleType="fitCenter"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintHeight_percent="0.85"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/currentDateTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/font24.bold"
        android:text="RABU, 25/02/2026"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/currentDayTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        style="@style/font20.bold"
        android:text="10:00:01"
        android:textAlignment="textStart"
        app:layout_constraintStart_toStartOf="@id/currentDateTime"
        app:layout_constraintTop_toBottomOf="@id/currentDateTime"
        app:layout_constraintEnd_toEndOf="@id/currentDateTime"/>

    <ImageView
        android:layout_width="120dp"
        android:layout_height="0dp"
        android:src="@drawable/karirjepang"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/currentDateTime"
        app:layout_constraintBottom_toBottomOf="@id/currentDayTime"/>

    <TextView
        android:id="@+id/tvTitleLaporanProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LAPORAN PROGRESS DIVISI"
        android:textAlignment="center"
        android:layout_marginTop="@dimen/dimen_margin_12"
        style="@style/font24.bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/currentDayTime"/>

    <View
        android:id="@+id/lineProgress"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/dark_blue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/dimen_margin_2"
        app:layout_constraintTop_toBottomOf="@id/tvTitleLaporanProgress"/>

    <!-- Dual-column header row -->
    <LinearLayout
        android:id="@+id/headerRow"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/lineProgress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Left header -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/dimen_margin_large"
            android:paddingTop="@dimen/dimen_padding_10"
            android:paddingBottom="@dimen/dimen_padding_10"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="NAMA DIVISI"
                style="@style/font14.bold"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="JOB DESCRIPTION"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                style="@style/font14.bold"
                android:layout_weight="1.5"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="PROGRESS%"
                style="@style/font14.bold"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_weight="1"/>

        </LinearLayout>

        <!-- Right header -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:paddingTop="@dimen/dimen_padding_10"
            android:paddingBottom="@dimen/dimen_padding_10"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="NAMA DIVISI"
                style="@style/font14.bold"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="JOB DESCRIPTION"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                style="@style/font14.bold"
                android:layout_weight="1.5"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="PROGRESS%"
                style="@style/font14.bold"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_weight="1"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Single RecyclerView for both columns — one scroll = silky smooth -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProgress"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/headerRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_progress_dual" />

</androidx.constraintlayout.widget.ConstraintLayout>