<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/signage_row_height"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginTop="@dimen/dimen_margin_6"
    android:paddingVertical="6dp"
    android:gravity="center_vertical"
    android:background="@color/color_secondary"
    android:baselineAligned="false"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tvTanggalTerbit"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        style="@style/font14.bold"
        android:textAlignment="center"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:layout_weight="1.5"
        tools:text="23/08/2027"/>

    <TextView
        android:id="@+id/tvSeparator1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:text=">"
        style="@style/font14.bold" />

    <TextView
        android:id="@+id/tvNamaPerusahaan"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        style="@style/font14.bold"
        android:textAlignment="center"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:layout_weight="2"
        tools:text="KIMURA TAKASHI (TSUCHINOWA NOUEN)"/>

    <TextView
        android:id="@+id/tvSeparator2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:text=">"
        style="@style/font14.bold" />

    <TextView
        android:id="@+id/tvNamaLPK"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        style="@style/font14.bold"
        android:textAlignment="center"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:layout_weight="2"/>

    <TextView
        android:id="@+id/tvSeparator3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:text=">"
        style="@style/font14.bold" />

    <TextView
        android:id="@+id/tvJumlahKandidat"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        style="@style/font14.bold"
        android:textAlignment="center"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:layout_weight="1.2"/>

</LinearLayout>
