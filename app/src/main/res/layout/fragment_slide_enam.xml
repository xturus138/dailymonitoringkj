<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.main.slide5.SlideLima">

    <TextView
        android:id="@+id/tvTitleJobOrder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="JADWAL TERBIT COE"
        android:textAlignment="center"
        style="@style/font24.bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <View
        android:id="@+id/lineJobOrder"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/dark_blue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/dimen_margin_2"
        app:layout_constraintTop_toBottomOf="@id/tvTitleJobOrder"/>

    <!-- Dual-column header row -->
    <LinearLayout
        android:id="@+id/headerRow"
        android:layout_width="match_parent"
        android:layout_height="@dimen/signage_header_height"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/lineJobOrder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Left header -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/dimen_margin_large"
            android:paddingTop="@dimen/dimen_padding_10"
            android:paddingBottom="@dimen/dimen_padding_10"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="TANGGAL"
                style="@style/font14.boldS"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_weight="1.5"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="PERUSAHAAN"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                style="@style/font14.boldS"
                android:layout_weight="2"/>
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="LPK"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                style="@style/font14.boldS"
                android:layout_weight="2"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="KANDIDAT"
                style="@style/font14.boldS"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_weight="0.8"/>

        </LinearLayout>

        <!-- Right header -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:paddingTop="@dimen/dimen_padding_10"
            android:paddingBottom="@dimen/dimen_padding_10"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="Tanggal Terbit"
                style="@style/font14.boldS"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_weight="2"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="NAMA PERUSAHAAN"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                style="@style/font14.boldS"
                android:layout_weight="2"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="NAMA LPK"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                style="@style/font14.boldS"
                android:layout_weight="2"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="J.KANDIDAT"
                style="@style/font14.boldS"
                android:textAlignment="center"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_weight="0.8"/>

        </LinearLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvJobOrder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/headerRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_jadwal_terbit_dual" />

</androidx.constraintlayout.widget.ConstraintLayout>
