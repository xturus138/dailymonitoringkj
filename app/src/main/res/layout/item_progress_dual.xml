<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:layout_marginTop="@dimen/dimen_margin_6"
    android:baselineAligned="false"
    android:orientation="horizontal">

    <!-- LEFT column -->
    <LinearLayout
        android:id="@+id/leftColumn"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginEnd="@dimen/dimen_margin_large"
        android:paddingVertical="6dp"
        android:gravity="center_vertical"
        android:background="@color/color_secondary"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvNamaDivisiLeft"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            style="@style/font14.bold"
            android:textAlignment="center"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvProjectLeft"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:textAlignment="center"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            style="@style/font12.bold"
            android:layout_weight="1.5"/>

        <TextView
            android:id="@+id/tvPersentaseLeft"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            style="@style/font14.bold"
            android:textAlignment="center"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_weight="1"/>

    </LinearLayout>

    <!-- RIGHT column -->
    <LinearLayout
        android:id="@+id/rightColumn"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:paddingVertical="6dp"
        android:gravity="center_vertical"
        android:background="@color/color_secondary"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvNamaDivisiRight"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            style="@style/font14.bold"
            android:textAlignment="center"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvProjectRight"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:textAlignment="center"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            style="@style/font12.bold"
            android:layout_weight="1.5"/>

        <TextView
            android:id="@+id/tvPersentaseRight"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            style="@style/font14.bold"
            android:textAlignment="center"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_weight="1"/>

    </LinearLayout>

</LinearLayout>
